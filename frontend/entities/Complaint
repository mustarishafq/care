{
  "name": "Complaint",
  "type": "object",
  "properties": {
    "ticket_id": {
      "type": "string",
      "description": "Auto-generated ticket ID"
    },
    "customer_name": {
      "type": "string",
      "description": "Customer full name"
    },
    "customer_phone": {
      "type": "string",
      "description": "Customer phone number"
    },
    "order_number": {
      "type": "string",
      "description": "Order reference number"
    },
    "order_source": {
      "type": "string",
      "enum": [
        "SiteGiant",
        "FounderHQ"
      ],
      "description": "Platform where the order was placed"
    },
    "purchase_date": {
      "type": "string",
      "format": "date",
      "description": "Date the customer purchased the order"
    },
    "batch_number": {
      "type": "string",
      "description": "Primary product batch or lot number (legacy)"
    },
    "product_name": {
      "type": "string",
      "description": "Primary product name (legacy)"
    },
    "quantity_affected": {
      "type": "number",
      "description": "Primary product quantity affected (legacy)"
    },
    "unit_of_measurement_id": {
      "type": "string",
      "description": "Primary unit of measurement lookup ID (legacy)"
    },
    "unit_of_measurement": {
      "type": "string",
      "description": "Primary unit for quantity affected (legacy)"
    },
    "affected_products": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "product_id": { "type": "string" },
          "product_name": { "type": "string" },
          "batch_number": { "type": "string" },
          "quantity_affected": { "type": "number" },
          "unit_of_measurement_id": { "type": "string" },
          "unit_of_measurement": { "type": "string" }
        }
      },
      "description": "Affected product lines, each pairing one batch number with its quantity and unit"
    },
    "complaint_type": {
      "type": "string",
      "enum": [
        "Damaged Product",
        "Broken Item",
        "Missing Item",
        "Wrong Item",
        "Leakage",
        "Packaging Damage",
        "Parcel Not Arrived",
        "Other"
      ],
      "description": "Type of complaint"
    },
    "description": {
      "type": "string",
      "description": "Detailed complaint description"
    },
    "proof_files": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URLs of uploaded proof images/videos/docs"
    },
    "courier_name": {
      "type": "string",
      "description": "Courier/shipping company"
    },
    "tracking_number": {
      "type": "string",
      "description": "Shipment tracking number"
    },
    "replacement_tracking_number": {
      "type": "string",
      "description": "Replacement shipment tracking"
    },
    "priority": {
      "type": "string",
      "enum": [
        "Low",
        "Medium",
        "High",
        "Urgent"
      ],
      "default": "Medium",
      "description": "Ticket priority level"
    },
    "status": {
      "type": "string",
      "enum": [
        "New Complaint",
        "Under Review",
        "Waiting for Customer",
        "Waiting for Vendor",
        "Approved Replacement",
        "Rejected",
        "Reprocessing by Fulfillment",
        "Ready to Ship",
        "Shipped",
        "Delivered",
        "Closed",
        "Drop"
      ],
      "default": "New Complaint",
      "description": "Current workflow status"
    },
    "assigned_department": {
      "type": "string",
      "enum": [
        "Customer Service",
        "Fulfillment",
        "Logistics",
        "Management"
      ],
      "description": "Department assigned"
    },
    "assigned_user": {
      "type": "string",
      "description": "Email of assigned user"
    },
    "assigned_user_name": {
      "type": "string",
      "description": "Name of assigned user"
    },
    "resolution_notes": {
      "type": "string",
      "description": "Final resolution notes"
    },
    "sla_deadline": {
      "type": "string",
      "format": "date-time",
      "description": "SLA deadline for resolution"
    },
    "sla_paused_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when SLA was paused (Waiting for Customer or Waiting for Vendor)"
    },
    "sla_paused_duration": {
      "type": "number",
      "description": "Total seconds SLA has been paused (accumulated)"
    },
    "first_response_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp of first response"
    },
    "resolved_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when resolved"
    },
    "delivered_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when marked as delivered"
    },
    "closed_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when closed"
    }
  },
  "required": [
    "customer_name",
    "tracking_number",
    "purchase_date",
    "complaint_type",
    "description"
  ]
}
{
  "name": "Role",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Role name"
    },
    "description": {
      "type": "string",
      "description": "Role description"
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of permission keys granted to this role"
    },
    "default_page": {
      "type": "string",
      "description": "Default landing page path after login",
      "default": "/dashboard"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "name"
  ]
}

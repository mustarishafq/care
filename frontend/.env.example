# Development: Vite proxies /api to the Laravel backend (see vite.config.js)
VITE_API_URL=/api/v1

# Production (separate API subdomain): set before `npm run build`
# VITE_API_URL=https://careapi.example.com/api/v1

# EMZI Nexus Brain platform URL (login redirect)
# VITE_NEXUS_BRAIN_URL=https://emzinexus.com
